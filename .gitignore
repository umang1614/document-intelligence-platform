# =========================
# Monorepo-wide ignores
# =========================

# Environment and secrets
.env
.env.*
*.env
*.pem
*.key
*.p12
*.jks

# Node.js (root and nested)
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Frontend build artifacts
frontend/dist/
frontend/dist-ssr/

# Backend build artifacts
backend/target/
backend/uploads/

# Generic logs and temp files
logs/
*.log
tmp/
temp/
*.tmp

# IDE/editor
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db
